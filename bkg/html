            <div class="menu-edit">White Delight (5,70 €) - <input type="text" class="price-input" id="p16" value="5.70"> € <button onclick="save('p16','s16')">Speichern</button> <span id="s16"></span></div>
            <div class="menu-edit">Pistachio Cream (8,20 €) - <input type="text" class="price-input" id="p17" value="8.20"> € <button onclick="save('p17','s17')">Speichern</button> <span id="s17"></span></div>
            <div class="menu-edit">Kinder Magic (7,50 €) - <input type="text" class="price-input" id="p18" value="7.50"> € <button onclick="save('p18','s18')">Speichern</button> <span id="s18"></span></div>
            <div class="menu-edit">Coco White (6,00 €) - <input type="text" class="price-input" id="p19" value="6.00"> € <button onclick="save('p19','s19')">Speichern</button> <span id="s19"></span></div>
