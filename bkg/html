            <div class="category-title">🧀 HERZHAFTE CRÊPES</div>
            <div class="menu-edit">Ham - Cheese Crêpe (7,00 €) - <input type="text" class="price-input" id="p23" value="7.00"> € <button onclick="save('p23','s23')">Speichern</button> <span id="s23"></span></div>
            <div class="menu-edit">Cheese Crêpe (6,50 €) - <input type="text" class="price-input" id="p24" value="6.50"> € <button onclick="save('p24','s24')">Speichern</button> <span id="s24"></span></div>
            <div class="menu-edit">Savoury Salami (7,00 €) - <input type="text" class="price-input" id="p25" value="7.00"> € <button onclick="save('p25','s25')">Speichern</button> <span id="s25"></span></div>
        `;
    }

    function save(priceId, spanId) {
        let price = document.getElementById(priceId).value;
        document.getElementById(spanId).innerText = '✅ ' + price + ' € gespeichert';
        setTimeout(() => { document.getElementById(spanId).innerText = ''; }, 2000);
    }
</script>

</body>
</html>